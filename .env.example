# Postiz — get your API key from https://app.postiz.com → Settings → API
POSTIZ_API_KEY=your-postiz-api-key
POSTIZ_API_URL=https://api.postiz.com/public/v1

# OpenAI — get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# Discord — create a webhook in your Discord server (Server Settings → Integrations → Webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-url

# Postiz Integration IDs — find these in Postiz after connecting TikTok/Instagram
TIKTOK_INTEGRATION_ID=your-tiktok-integration-id
INSTAGRAM_INTEGRATION_ID=your-instagram-integration-id

# Your timezone (used for scheduling posts and daily reports)
TIMEZONE=America/New_York

# ─── OPTIONAL: Discord Chat Bot ───────────────────────────────────────────────
# Create a bot at https://discord.com/developers/applications
# → New Application → Bot → Copy Token
# Enable "Message Content Intent" under Privileged Gateway Intents
# Invite bot to your server with: Messages + Message Content permissions
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# ─── OPTIONAL: Chat/Thinking LLM ──────────────────────────────────────────────
# Model used for creative director, hooks, research analysis, and Discord chat
# Default: gpt-4o-mini (fast and cheap). Change to gpt-4o for higher quality.
OPENAI_CHAT_MODEL=gpt-4o-mini
